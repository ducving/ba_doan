{
	"info": {
		"_postman_id": "php-api-auth-collection",
		"name": "PHP API - Đăng ký/Đăng nhập",
		"description": "Collection để test API đăng ký và đăng nhập",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register - Đăng ký",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Nguyễn Văn A\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost/doan/api/register.php",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"path": [
						"doan",
						"api",
						"register.php"
					]
				},
				"description": "Đăng ký tài khoản mới"
			},
			"response": []
		},
		{
			"name": "2. Login - Đăng nhập",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Lưu token vào environment variable",
							"var jsonData = pm.response.json();",
							"if (jsonData.token) {",
							"    pm.environment.set(\"token\", jsonData.token);",
							"    console.log(\"Token đã được lưu: \" + jsonData.token);",
							"}",
							"",
							"// Test cases",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has token\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('token');",
							"});",
							"",
							"pm.test(\"Response has user info\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('user');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost/doan/api/login.php",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"path": [
						"doan",
						"api",
						"login.php"
					]
				},
				"description": "Đăng nhập và nhận JWT token"
			},
			"response": []
		},
		{
			"name": "3. Verify Token",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text",
						"description": "Token từ login/register"
					}
				],
				"url": {
					"raw": "http://localhost/doan/api/verify_token.php",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"path": [
						"doan",
						"api",
						"verify_token.php"
					]
				},
				"description": "Xác thực JWT token"
			},
			"response": []
		},
		{
			"name": "4. Register - Test Password yếu",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test2@example.com\",\n    \"password\": \"123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost/doan/api/register.php",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"path": [
						"doan",
						"api",
						"register.php"
					]
				},
				"description": "Test validation - password yếu"
			},
			"response": []
		},
		{
			"name": "5. Login - Test sai mật khẩu",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"SaiMatKhau123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost/doan/api/login.php",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"path": [
						"doan",
						"api",
						"login.php"
					]
				},
				"description": "Test đăng nhập với mật khẩu sai"
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost/doan",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	]
}
